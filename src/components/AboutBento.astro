---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { MapPin, Briefcase, Code2, LineChart, Globe, Trophy } from "lucide-react";
---

<section id="about" class="pt-10 md:pt-20 pb-6 md:pb-12">
    <div class="mb-12 md:mb-16 max-w-3xl">
        <div class="space-y-6">
            <div class="inline-block">
                <span class="text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full bg-primary-neon/10 text-primary-neon border border-primary-neon/20" data-i18n-key="about.badge">Who I Am</span>
            </div>
            <h2 class="text-4xl md:text-6xl font-extrabold text-foreground tracking-tight" data-i18n-key="about.title">About Me</h2>
            <div class="h-1.5 w-24 bg-primary-neon rounded-full shadow-[0_0_15px_rgba(56,189,248,0.5)]"></div>
            <p class="text-lg md:text-xl text-muted-foreground leading-relaxed font-light" data-i18n-key="about.description">
                Starting my journey navigating complex business logic, I've transitioned deeply into backend architectures and cloud infrastructure. I thrive on solving performance bottlenecks and building scalable systems that directly impact user experiences. Currently contributing at Kementerian PU while pursuing informatics studies.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(180px,auto)]">
        
        <!-- Profile Block -->
        <Card className="md:col-span-1 bg-card/40 backdrop-blur-md rounded-2xl border border-border relative overflow-hidden group hover:border-primary-neon/40 hover:-translate-y-1 hover:shadow-[0_10px_30px_-10px_rgba(56,189,248,0.2)] transition-all duration-300">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-neon/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <CardContent className="p-0 h-full flex flex-col relative z-10">
                <div class="h-32 w-full bg-muted/30 relative overflow-hidden">
                    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80')] bg-cover bg-center opacity-20 mix-blend-luminosity"></div>
                </div>
                <div class="px-6 pb-6 pt-0 relative flex-1 flex flex-col">
                    <div class="w-20 h-20 rounded-full bg-muted border-4 border-card -mt-10 overflow-hidden relative z-20 shadow-lg flex items-center justify-center grayscale hover:grayscale-0 transition-all duration-500">
                        <!-- TODO: Replace with Real Photo Avatar -->
                        <div class="absolute inset-0 bg-gradient-to-br from-primary-neon/20 to-secondary-neon/20 mix-blend-overlay"></div>
                        <span class="text-3xl font-extrabold text-foreground/50">FA</span>
                    </div>
                    <div class="mt-4">
                        <h3 class="text-xl font-bold mb-1 text-foreground flex items-center gap-2"><span data-i18n-key="about.profile.name">Farhan Ali</span> <span class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"></span></h3>
                        <p class="text-primary-neon text-sm font-medium mb-3" data-i18n-key="about.profile.title">Backend & DevOps Engineer</p>
                        <div class="flex items-center gap-1.5 text-muted-foreground text-xs font-medium bg-secondary px-2.5 py-1.5 rounded-md w-fit border border-border">
                            <MapPin className="w-3.5 h-3.5" />
                            <span>Jakarta, ID (Remote Ready)</span>
                        </div>
                    </div>
                </div>
            </CardContent>
        </Card>

        <!-- Experience Block -->
        <Card className="md:col-span-2 group overflow-hidden bg-card/40 backdrop-blur-md rounded-2xl border border-border hover:border-primary-neon/40 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 relative">
            <div class="absolute inset-0 bg-gradient-to-br from-secondary-neon/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <CardContent className="p-6 h-full flex flex-col justify-center relative z-10">
                 <div class="flex items-start justify-between mb-4">
                    <div class="w-12 h-12 rounded-xl bg-secondary-neon/10 flex items-center justify-center text-secondary-neon group-hover:scale-110 transition-transform duration-300">
                        <Briefcase className="w-6 h-6" />
                    </div>
                    <span class="text-xs font-bold uppercase tracking-widest py-1.5 px-3 rounded-full bg-secondary text-foreground/80 border border-border" data-i18n-key="about.current">Currently</span>
                </div>
                <h3 class="text-2xl font-bold mb-2 text-foreground" data-i18n-key="about.experience.title">Intern Fullstack Developer</h3>
                <p class="text-primary-neon mb-3 font-semibold tracking-wide" data-i18n-key="about.experience.company">Pusdatin, Kementerian PU</p>
                <p class="text-muted-foreground text-sm leading-relaxed" data-i18n-key="about.experience.description">Managing CI/CD pipelines, cloud infrastructure (AWS), containerization (Docker, Kubernetes), and building enterprise-grade administrative backend systems handling massive concurrent workloads.</p>
            </CardContent>
        </Card>

        <!-- Tech Stack Block -->
        <Card className="md:col-span-2 md:row-span-2 relative overflow-hidden bg-card/40 backdrop-blur-md rounded-2xl border border-border group hover:border-primary-neon/40 transition-all duration-300">
             <div class="absolute inset-0 bg-gradient-to-br from-foreground/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <CardHeader className="pt-6 px-6 relative z-10">
                <CardTitle className="flex items-center gap-2 text-foreground">
                    <Code2 className="w-6 h-6 text-primary-neon" />
                    <span data-i18n-key="about.tech.title">Tech Stack</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="grid grid-cols-2 sm:grid-cols-4 gap-3 p-6 pt-2 relative z-10">
                {['Go', 'Node.js', 'PHP', 'Gin', 'React', 'Next.js', 'Laravel', 'Tailwind', 'PostgreSQL', 'MySQL', 'MongoDB', 'Docker', 'Kubernetes', 'AWS', 'Jenkins', 'Gihub Action'].map((tech) => (
                   <div class="flex flex-col items-center justify-center p-3 rounded-xl bg-secondary/50 hover:bg-secondary text-muted-foreground hover:text-primary-neon transition-all duration-300 border border-border hover:border-primary-neon/30 hover:-translate-y-1 hover:shadow-md">
                        <span class="font-semibold text-xs sm:text-sm transition-transform">{tech}</span>
                   </div>
               ))}
            </CardContent>
        </Card>

        <!-- Interests Block -->
        <Card className="md:col-span-1 bg-card/40 backdrop-blur-md rounded-2xl border border-border group hover:border-primary-neon/40 hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
            <CardContent className="p-6 h-full flex flex-col justify-center gap-5">
                <div class="flex items-center gap-3">
                    <div class="p-2.5 rounded-xl bg-primary-neon/10 text-primary-neon group-hover:scale-110 transition-transform duration-300">
                        <Globe className="w-5 h-5" />
                    </div>
                    <span class="font-semibold text-foreground/90" data-i18n-key="about.interest.cloud">Cloud Infrastructure</span>
                </div>
                 <div class="flex items-center gap-3">
                    <div class="p-2.5 rounded-xl bg-secondary-neon/10 text-secondary-neon group-hover:scale-110 transition-transform duration-300">
                        <LineChart className="w-5 h-5" />
                    </div>
                    <span class="font-semibold text-foreground/90" data-i18n-key="about.interest.cicd">CI/CD Automation</span>
                </div>
                 <div class="flex items-center gap-3">
                    <div class="p-2.5 rounded-xl bg-green-500/10 text-green-600 dark:text-green-400 group-hover:scale-110 transition-transform duration-300">
                        <Trophy className="w-5 h-5" />
                    </div>
                    <span class="font-semibold text-foreground/90" data-i18n-key="about.interest.system">System Design</span>
                </div>
            </CardContent>
        </Card>
        
        <!-- Education / Stat Block -->
         <Card className="md:col-span-1 relative overflow-hidden bg-primary-neon/5 backdrop-blur-md rounded-2xl border border-primary-neon/10 group hover:border-primary-neon/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(56,189,248,0.15)] transition-all duration-300">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary-neon/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <CardContent className="p-6 h-full flex flex-col justify-center text-center relative z-10">
                <div class="text-5xl font-extrabold text-primary-neon mb-3 tracking-tighter">3+</div>
                <p class="text-sm text-secondary-neon font-bold uppercase tracking-widest" data-i18n-key="about.years.label">Years Coding</p>
            </CardContent>
        </Card>

    </div>
</section>
