---
const stack = [
  { name: "Laravel", slug: "laravel", highlight: false },
  { name: "Next.js", slug: "nextdotjs", highlight: false },
  { name: "React", slug: "react", highlight: false },
  { name: "Tailwind CSS", slug: "tailwindcss", highlight: false },
  { name: "Go", slug: "go", highlight: true },
  { name: "Python", slug: "python", highlight: false },
  { name: "PostgreSQL", slug: "postgresql", highlight: true },
  { name: "MongoDB", slug: "mongodb", highlight: false },
  { name: "Docker", slug: "docker", highlight: false },
  { name: "Kubernetes", slug: "kubernetes", highlight: false },
];
---

<section class="py-6 overflow-hidden relative group/marquee z-10 w-full pt-4 [mask-image:linear-gradient(to_right,transparent,black_15%,black_85%,transparent)]">
    <div class="text-center mb-6">
        <h3 class="text-[10px] font-semibold tracking-[0.3em] uppercase text-muted-foreground/50">Trusted Stack & Technologies</h3>
    </div>

    <div class="flex overflow-hidden group">
        <div class="flex animate-marquee group-hover:pause items-center">
            {stack.map((item) => (
                <div class="flex items-center justify-center w-16 h-16 md:w-20 md:h-20 mx-8 cursor-default group/icon flex-shrink-0">
                    <img 
                      src={`https://cdn.simpleicons.org/${item.slug}/${item.highlight ? '38BDF8' : '888888'}`} 
                      alt={`Logo ${item.name}`} 
                      title={`${item.name}`}
                      loading="lazy"
                      decoding="async"
                      width="40"
                      height="40"
                      class="w-10 h-10 md:w-12 md:h-12 object-contain opacity-40 grayscale transition-all duration-500 ease-out group-hover/icon:opacity-100 group-hover/icon:grayscale-0 group-hover/icon:scale-110 group-hover/icon:drop-shadow-[0_0_15px_rgba(56,189,248,0.3)] dark:group-hover/icon:drop-shadow-[0_0_15px_rgba(255,255,255,0.3)]" 
                    />
                </div>
            ))}
        </div>
        <div class="flex animate-marquee group-hover:pause items-center" aria-hidden="true">
            {stack.map((item) => (
                <div class="flex items-center justify-center w-16 h-16 md:w-20 md:h-20 mx-8 cursor-default group/icon flex-shrink-0">
                    <img 
                      src={`https://cdn.simpleicons.org/${item.slug}/${item.highlight ? '38BDF8' : 'white'}`} 
                      alt={`Logo ${item.name}`} 
                      title={`${item.name}`}
                      loading="lazy"
                      decoding="async"
                      width="40"
                      height="40"
                      class="w-10 h-10 md:w-12 md:h-12 object-contain opacity-40 grayscale transition-all duration-500 ease-out group-hover/icon:opacity-100 group-hover/icon:grayscale-0 group-hover/icon:scale-110 group-hover/icon:drop-shadow-[0_0_15px_rgba(255,255,255,0.3)]" 
                    />
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    @keyframes marquee {
        0% { 
            transform: translateX(0); 
        }
        to { 
            transform: translateX(calc(-100% - 3rem)); 
        }
    }
    .animate-marquee {
        animation: marquee 40s linear infinite;
        will-change: transform;
    }
    .group:hover .group-hover\:pause {
        animation-play-state: paused;
    }
</style>
