---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Cloud, Zap, Database, Layout, Shield } from "lucide-react";
---

<section id="about-description" class="py-12 md:py-16">
    <div class="mb-10 md:mb-12">
        <span class="text-xs font-bold tracking-widest uppercase px-4 py-1.5 rounded-full bg-primary-neon/10 text-primary-neon border border-primary-neon/20 mb-6 inline-block" data-i18n-key="aboutDescription.badge">Specialization</span>
        <h2 class="text-3xl md:text-5xl font-extrabold mb-6 tracking-tight text-foreground" data-i18n-key="aboutDescription.heading">Core Competencies</h2>
        <div class="h-1.5 w-24 bg-primary-neon rounded-full shadow-[0_0_15px_rgba(56,189,248,0.5)] mb-8"></div>
        <p class="text-lg md:text-xl text-foreground/80 max-w-3xl leading-relaxed font-light" data-i18n-key="aboutDescription.lead">
            I don't just write code; I design systems. Specializing in high-performance backend architectures and resilient infrastructure, I focus on delivering scalable solutions that directly impact business speed and stability.
        </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        
        <!-- Backend Development -->
        <Card className="bg-card/40 backdrop-blur-xl border border-border hover:border-primary-neon/40 hover:-translate-y-2 hover:shadow-[0_15px_40px_-5px_rgba(56,189,248,0.25)] transition-all duration-500 group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-neon/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <CardHeader className="relative z-10">
                <CardTitle className="flex items-center gap-4">
                    <div class="p-3 rounded-2xl bg-primary-neon/10 text-primary-neon backdrop-blur-md border border-primary-neon/20 group-hover:scale-110 group-hover:bg-primary-neon/20 transition-all duration-500 shadow-[0_0_15px_rgba(56,189,248,0.1)]">
                        <Layout className="w-6 h-6" />
                    </div>
                    <span class="text-foreground font-bold tracking-wide" data-i18n-key="aboutDescription.backend.title">Backend Development</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="space-y-5 text-muted-foreground relative z-10">
                <p class="text-foreground/70 leading-relaxed text-sm" data-i18n-key="aboutDescription.backend.text">Built robust REST APIs handling <strong class="text-primary-neon drop-shadow-[0_0_8px_rgba(56,189,248,0.5)]">10k+ requests/day</strong> with optimized performance using Go, Express.js, and Laravel. Focused on complex database queries and tight security.</p>
                <div class="flex flex-wrap gap-2">
                    <span class="text-xs px-2.5 py-1 rounded bg-primary-neon/10 text-primary-neon border border-primary-neon/20 font-medium" data-i18n-key="aboutDescription.backend.tag1">Go</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-primary-neon/10 text-primary-neon border border-primary-neon/20 font-medium" data-i18n-key="aboutDescription.backend.tag2">Express.js</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-primary-neon/10 text-primary-neon border border-primary-neon/20 font-medium" data-i18n-key="aboutDescription.backend.tag3">Laravel</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-primary-neon/10 text-primary-neon border border-primary-neon/20 font-medium" data-i18n-key="aboutDescription.backend.tag4">REST APIs</span>
                </div>
            </CardContent>
        </Card>

        <!-- Cloud Infrastructure -->
        <Card className="bg-card/40 backdrop-blur-xl border border-border hover:border-secondary-neon/40 hover:-translate-y-2 hover:shadow-[0_15px_40px_-5px_rgba(167,139,250,0.25)] transition-all duration-500 group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-secondary-neon/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <CardHeader className="relative z-10">
                <CardTitle className="flex items-center gap-4">
                    <div class="p-3 rounded-2xl bg-secondary-neon/10 text-secondary-neon backdrop-blur-md border border-secondary-neon/20 group-hover:scale-110 group-hover:bg-secondary-neon/20 transition-all duration-500 shadow-[0_0_15px_rgba(167,139,250,0.1)]">
                        <Cloud className="w-6 h-6" />
                    </div>
                    <span class="text-foreground font-bold tracking-wide" data-i18n-key="aboutDescription.cloud.title">Cloud & Infrastructure</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="space-y-5 text-muted-foreground relative z-10">
                <p class="text-foreground/70 leading-relaxed text-sm" data-i18n-key="aboutDescription.cloud.text">Experienced in deploying auto-scaling infrastructure ensuring <strong class="text-secondary-neon drop-shadow-[0_0_8px_rgba(167,139,250,0.5)]">99.9% uptime</strong>. Strong expertise in Docker containerization and Kubernetes orchestration.</p>
                <div class="flex flex-wrap gap-2">
                    <span class="text-xs px-2.5 py-1 rounded bg-secondary-neon/10 text-secondary-neon border border-secondary-neon/20 font-medium" data-i18n-key="aboutDescription.cloud.tag1">AWS</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-secondary-neon/10 text-secondary-neon border border-secondary-neon/20 font-medium" data-i18n-key="aboutDescription.cloud.tag2">Docker</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-secondary-neon/10 text-secondary-neon border border-secondary-neon/20 font-medium" data-i18n-key="aboutDescription.cloud.tag3">Kubernetes</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-secondary-neon/10 text-secondary-neon border border-secondary-neon/20 font-medium" data-i18n-key="aboutDescription.cloud.tag4">Linux</span>
                </div>
            </CardContent>
        </Card>

        <!-- CI/CD & DevOps -->
        <Card className="bg-card/40 backdrop-blur-xl border border-border hover:border-green-400/40 hover:-translate-y-2 hover:shadow-[0_15px_40px_-5px_rgba(74,222,128,0.2)] transition-all duration-500 group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-green-400/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <CardHeader className="relative z-10">
                <CardTitle className="flex items-center gap-4">
                    <div class="p-3 rounded-2xl bg-green-500/10 text-green-600 dark:text-green-400 backdrop-blur-md border border-green-500/20 group-hover:scale-110 group-hover:bg-green-500/20 transition-all duration-500 shadow-[0_0_15px_rgba(74,222,128,0.1)]">
                        <Shield className="w-6 h-6" />
                    </div>
                    <span class="text-foreground font-bold tracking-wide" data-i18n-key="aboutDescription.cicd.title">CI/CD & Automation</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="space-y-5 text-muted-foreground relative z-10">
                <p class="text-foreground/70 leading-relaxed text-sm" data-i18n-key="aboutDescription.cicd.text">Reducing deployment time by <strong class="text-green-600 dark:text-green-400 drop-shadow-[0_0_8px_rgba(74,222,128,0.5)]">40%</strong> through automated testing and continuous delivery pipelines utilizing Jenkins and GitLab CI.</p>
                <div class="flex flex-wrap gap-2">
                    <span class="text-xs px-2.5 py-1 rounded bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20 font-medium" data-i18n-key="aboutDescription.cicd.tag1">Jenkins</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20 font-medium" data-i18n-key="aboutDescription.cicd.tag2">GitLab CI</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20 font-medium" data-i18n-key="aboutDescription.cicd.tag3">Automation</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20 font-medium" data-i18n-key="aboutDescription.cicd.tag4">GitHub Actions</span>
                </div>
            </CardContent>
        </Card>

        <!-- Database Management -->
        <Card className="bg-card/40 backdrop-blur-xl border border-border hover:border-orange-400/40 hover:-translate-y-2 hover:shadow-[0_15px_40px_-5px_rgba(251,146,60,0.2)] transition-all duration-500 group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-400/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <CardHeader className="relative z-10">
                <CardTitle className="flex items-center gap-4">
                    <div class="p-3 rounded-2xl bg-orange-500/10 text-orange-600 dark:text-orange-400 backdrop-blur-md border border-orange-500/20 group-hover:scale-110 group-hover:bg-orange-500/20 transition-all duration-500 shadow-[0_0_15px_rgba(251,146,60,0.1)]">
                        <Database className="w-6 h-6" />
                    </div>
                    <span class="text-foreground font-bold tracking-wide" data-i18n-key="aboutDescription.database.title">Database Architecture</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="space-y-5 text-muted-foreground relative z-10">
                <p class="text-foreground/70 leading-relaxed text-sm" data-i18n-key="aboutDescription.database.text">Ensuring sub-second queries by optimizing indexing and architectures in relational (PostgreSQL, MySQL) and NoSQL (MongoDB) data stores.</p>
                <div class="flex flex-wrap gap-2">
                    <span class="text-xs px-2.5 py-1 rounded bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20 font-medium" data-i18n-key="aboutDescription.database.tag1">PostgreSQL</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20 font-medium" data-i18n-key="aboutDescription.database.tag2">MySQL</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20 font-medium" data-i18n-key="aboutDescription.database.tag3">MongoDB</span>
                    <span class="text-xs px-2.5 py-1 rounded bg-orange-500/10 text-orange-600 dark:text-orange-400 border border-orange-500/20 font-medium" data-i18n-key="aboutDescription.database.tag4">Redis</span>
                </div>
            </CardContent>
        </Card>
        
        <!-- Frontend Support (Moved to last, less focus) -->
        <Card className="bg-card/40 backdrop-blur-xl border border-border hover:border-accent-neon/40 hover:-translate-y-2 hover:shadow-[0_15px_40px_-5px_rgba(255,255,255,0.05)] transition-all duration-500 group md:col-span-2 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-accent-neon/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <CardHeader className="relative z-10">
                <CardTitle className="flex items-center gap-4">
                    <div class="p-3 rounded-2xl bg-accent-neon/10 text-accent-neon backdrop-blur-md border border-accent-neon/20 group-hover:scale-110 group-hover:bg-accent-neon/20 transition-all duration-500 shadow-[0_0_15px_rgba(156,163,175,0.1)]">
                        <Zap className="w-6 h-6" />
                    </div>
                    <span class="text-foreground font-bold tracking-wide" data-i18n-key="aboutDescription.frontend.title">Frontend Integrations</span>
                </CardTitle>
            </CardHeader>
            <CardContent className="space-y-5 text-muted-foreground relative z-10">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                    <p class="text-foreground/70 leading-relaxed text-sm max-w-2xl" data-i18n-key="aboutDescription.frontend.text">Supporting seamless fullstack delivery by developing intuitive administrative dashboards and client-facing interfaces with React and Next.js.</p>
                    <div class="flex flex-wrap gap-2 shrink-0">
                        <span class="text-xs px-2.5 py-1 rounded bg-accent-neon/10 text-accent-neon border border-accent-neon/20 font-medium" data-i18n-key="aboutDescription.frontend.tag1">React</span>
                        <span class="text-xs px-2.5 py-1 rounded bg-accent-neon/10 text-accent-neon border border-accent-neon/20 font-medium" data-i18n-key="aboutDescription.frontend.tag2">Next.js</span>
                        <span class="text-xs px-2.5 py-1 rounded bg-accent-neon/10 text-accent-neon border border-accent-neon/20 font-medium" data-i18n-key="aboutDescription.frontend.tag4">Tailwind</span>
                    </div>
                </div>
            </CardContent>
        </Card>
    </div>

    <div class="mt-8 p-6 md:p-8 rounded-2xl border border-primary-neon/20 bg-primary-neon/5 backdrop-blur-md shadow-inner">
        <p class="text-foreground/80 leading-relaxed font-medium" data-i18n-key="aboutDescription.note">
            I am always open to discussing emerging technologies and exciting engineering challenges. Feel free to reach out to explore how I can bring measurable value to your infrastructure through efficient development practices and innovative problem solving.
        </p>
    </div>
</section>
