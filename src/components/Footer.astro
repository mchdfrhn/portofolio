---
import { Github, Linkedin, Mail, Code, Heart, ArrowUp } from "lucide-react";
import { GITHUB_URL, LINKEDIN_URL, EMAIL, SITE_TITLE, SITE_DESCRIPTION } from "../lib/config";
---

<footer class="bg-background border-t border-border py-16 mt-20 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-10 left-10 w-32 h-32 border border-primary/20 rounded-full"></div>
    <div class="absolute bottom-10 right-10 w-24 h-24 border border-primary/20 rounded-full"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-40 h-40 border border-primary/20 rounded-full"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand Section -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <Code class="text-primary w-6 h-6" />
          <span class="text-xl font-bold">{SITE_TITLE}</span>
        </div>
        <p class="text-muted-foreground mb-4 max-w-md">
          {SITE_DESCRIPTION}
        </p>
        <p class="text-sm text-muted-foreground">
          <span data-i18n-key="footer.builtWith">Built with Astro, React & Tailwind.</span>
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold mb-4 text-foreground">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="#about" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#about', {offset: -80});" class="text-muted-foreground hover:text-primary transition-colors text-sm" data-i18n-key="nav.about">About</a></li>
          <li><a href="#about-description" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#about-description', {offset: -80});" class="text-muted-foreground hover:text-primary transition-colors text-sm" data-i18n-key="nav.expertise">Expertise</a></li>
          <li><a href="#projects" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#projects', {offset: -80});" class="text-muted-foreground hover:text-primary transition-colors text-sm" data-i18n-key="nav.projects">Projects</a></li>
          <li><a href="#experience" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#experience', {offset: -80});" class="text-muted-foreground hover:text-primary transition-colors text-sm" data-i18n-key="nav.experience">Experience</a></li>
          <li><a href="#contact" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#contact', {offset: -80});" class="text-muted-foreground hover:text-primary transition-colors text-sm" data-i18n-key="nav.contact">Contact</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="font-semibold mb-4 text-foreground">Connect</h3>
        <div class="flex gap-4">
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors p-2 hover:bg-primary/10 rounded-lg"
            aria-label="GitHub"
          >
            <Github className="w-5 h-5" />
          </a>
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors p-2 hover:bg-primary/10 rounded-lg"
            aria-label="LinkedIn"
          >
            <Linkedin className="w-5 h-5" />
          </a>
          <a
            href={`mailto:${EMAIL}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors p-2 hover:bg-primary/10 rounded-lg"
            aria-label="Email"
          >
            <Mail className="w-5 h-5" />
          </a>
        </div>
        <p class="text-sm text-muted-foreground mt-4">
          Let's build something amazing together!
        </p>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-border pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-muted-foreground">
        &copy; {new Date().getFullYear()} <span data-i18n-key="footer.rights">All rights reserved.</span>
      </p>
      <div class="flex items-center gap-2 text-sm text-muted-foreground">
        <span>Made with</span>
        <Heart class="w-4 h-4 text-red-500 fill-current" />
        <span>by Mochamad Farhan Ali</span>
      </div>
    </div>

    <!-- Back to Top Button -->
    <button
      onclick="window.lenis ? window.lenis.scrollTo(0, {immediate: false}) : window.scrollTo({top: 0, behavior: 'smooth'})"
      class="fixed bottom-8 right-8 bg-primary/20 hover:bg-primary/30 text-primary p-3 rounded-full backdrop-blur-sm border border-primary/20 transition-all duration-300 opacity-0 translate-y-4 group"
      id="back-to-top"
    >
      <ArrowUp class="w-5 h-5 group-hover:-translate-y-1 transition-transform" />
    </button>
  </div>
</footer>

<script>
  // Show/hide back to top button
  const backToTopBtn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopBtn?.classList.remove('opacity-0', 'translate-y-4');
      backToTopBtn?.classList.add('opacity-100', 'translate-y-0');
    } else {
      backToTopBtn?.classList.remove('opacity-100', 'translate-y-0');
      backToTopBtn?.classList.add('opacity-0', 'translate-y-4');
    }
  });
</script>
