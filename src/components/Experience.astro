<section id="experience" class="py-24 relative overflow-hidden">
    <div class="mb-16 text-center md:text-left">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">Experience & Education</h2>
        <div class="h-1 w-20 bg-primary-neon shadow-neon md:mx-0 mx-auto"></div>
    </div>

    <div class="relative border-l border-primary-neon/10 ml-4 md:ml-12 space-y-12">
        
        <!-- Experience Item 1 -->
        <div class="relative pl-8 md:pl-12">
            <!-- Timeline Dot -->
             <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-primary-neon shadow-neon ring-4 ring-background"></div>
             
             <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                <h3 class="text-2xl font-bold">Intern Fullstack Developer</h3>
                <span class="text-xs font-mono text-primary-neon bg-primary-neon/10 px-3 py-1 rounded-full w-fit shadow-[0_0_10px_rgba(0,243,255,0.1)] neon-glow-blue border border-primary-neon/20">2025 - Present</span>
             </div>
             <div class="text-lg text-primary-neon mb-4 font-bold opacity-90">Pusdatin, Kementerian PUPR</div>
             <p class="text-muted-foreground max-w-3xl">
                 Developed and maintained critical administrative systems for the Ministry of Public Works. 
                 Optimized database queries for Sipekad, reducing load times by 40%. 
                 Collaborated with senior engineers to implement new features using React and Express.js.
             </p>
        </div>

        <!-- Education Item -->
         <div class="relative pl-8 md:pl-12">
            <!-- Timeline Dot -->
             <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-secondary-neon shadow-neon-purple ring-4 ring-background"></div>
             
             <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                <h3 class="text-2xl font-bold">Informatics Engineering</h3>
                <span class="text-xs font-mono text-secondary-neon bg-secondary-neon/10 px-3 py-1 rounded-full w-fit shadow-[0_0_10px_rgba(188,19,254,0.1)] neon-glow-purple border border-secondary-neon/20">2023 - Present</span>
             </div>
             <div class="text-lg text-secondary-neon mb-4 font-bold opacity-90">STT Pekerjaan Umum</div>
             <p class="text-muted-foreground max-w-3xl">
                 Focusing on Software Engineering, Data Structures, and Algorithm Design. 
                 Active member of the university coding club. 
                 Relevant Coursework: Web Development, Database Systems, Artificial Intelligence.
             </p>
        </div>
    </div>
</section>
