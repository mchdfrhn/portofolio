---
import { Button } from "@/components/ui/button";
import { ArrowRight, Mail } from "lucide-react";
import { motion } from "framer-motion";

---

<section id="hero" class="min-h-screen flex flex-col justify-center relative overflow-hidden">
    <!-- Subtle Background Depth & Seamless Orbs -->
    <div class="absolute top-[-10%] right-[10%] w-[500px] h-[500px] bg-primary-neon/10 blur-[150px] rounded-full -z-10 pointer-events-none"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[500px] h-[500px] bg-secondary-neon/10 blur-[150px] rounded-full -z-10 pointer-events-none"></div>

    <div class="w-full max-w-none md:max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16 flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-8">
        <div class="flex-1 space-y-10 relative z-10 w-full pl-0">
            <!-- Role / Tagline Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-neon/10 border border-primary-neon/30 animate-fade-in-up hover:border-primary-neon/50 hover:shadow-[0_0_15px_rgba(56,189,248,0.2)] transition-all">
                <span class="w-2 h-2 rounded-full bg-primary-neon animate-pulse shadow-[0_0_8px_rgba(56,189,248,0.6)]"></span>
                <span class="text-xs sm:text-sm font-bold tracking-widest text-primary-neon uppercase" data-i18n-key="hero.badge">Available for new opportunities</span>
            </div>

            <!-- Main Headline (Hierarchy) -->
            <div class="space-y-6">
                <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-foreground leading-[1.1] text-glow-primary">
                    <span class="block" data-i18n-key="hero.title.1">Fullstack Developer</span>
                    <span class="block text-primary-neon mt-2 text-4xl md:text-5xl" data-i18n-key="hero.title.2">(Next.js + Laravel + Go)</span>
                </h1>
                
                <p class="text-xl md:text-2xl text-muted-foreground max-w-2xl leading-relaxed font-light" data-i18n-key="hero.subtitle">
                    I Build Scalable Backend Systems That Handle Real-World Traffic.
                </p>
                
                <!-- Quick Impact / Stats -->
                <div class="flex flex-wrap gap-4 pt-2 pb-4">
                    <div class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-card/40 border border-border hover:bg-card/60 hover:border-primary-neon/30 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 backdrop-blur-md">
                        <span class="text-lg drop-shadow-md">🚀</span>
                        <span class="font-medium text-foreground/90">3+ Production Projects</span>
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-card/40 border border-border hover:bg-card/60 hover:border-primary-neon/30 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 backdrop-blur-md">
                        <span class="text-secondary-neon drop-shadow-[0_0_10px_rgba(167,139,250,0.3)]">⚙️</span>
                        <span class="font-medium text-foreground/90">REST API</span>
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-card/40 border border-border hover:bg-card/60 hover:border-primary-neon/30 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 backdrop-blur-md">
                        <span class="text-primary-neon drop-shadow-[0_0_10px_rgba(56,189,248,0.3)]">🐘</span>
                        <span class="font-medium text-foreground/90">PostgreSQL</span>
                    </div>
                    <div class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-card/40 border border-border hover:bg-card/60 hover:border-primary-neon/30 transition-all shadow-sm hover:shadow-lg hover:-translate-y-1 duration-300 backdrop-blur-md">
                        <span class="text-blue-500 drop-shadow-[0_0_10px_rgba(59,130,246,0.3)]">🐳</span>
                        <span class="font-medium text-foreground/90">Docker</span>
                    </div>
                </div>
            </div>

            <!-- CTA Section -->
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
                <a href="#contact" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#contact', {offset: -80});" class="inline-flex items-center justify-center whitespace-nowrap rounded-md ring-offset-background disabled:pointer-events-none disabled:opacity-50 h-[52px] w-full sm:w-auto px-8 text-[15px] btn-gradient-glow text-white font-extrabold border-none tracking-wide">
                    <span data-i18n-key="hero.cta.contact">Hire Me</span>
                    <Mail className="ml-2 w-[18px] h-[18px]" />
                </a>
                <a href="#projects" onclick="event.preventDefault(); window.lenis && window.lenis.scrollTo('#projects', {offset: -80});" class="inline-flex items-center justify-center whitespace-nowrap rounded-md ring-offset-background disabled:pointer-events-none disabled:opacity-50 h-[52px] w-full sm:w-auto px-8 text-[15px] border border-border text-foreground hover:bg-secondary hover:border-primary-neon/50 hover:-translate-y-1 transition-all duration-300 shadow-sm font-medium bg-card/50 backdrop-blur-sm">
                    <span data-i18n-key="hero.cta.projects">Projects</span>
                    <ArrowRight className="ml-2 w-[18px] h-[18px]" />
                </a>
            </div>
        </div>

        <!-- Right Side Visual / Hero Card -->
        <div class="flex-1 w-full max-w-xl relative hidden lg:block hero-visual opacity-90 overflow-hidden">
            <div class="bg-card/70 backdrop-blur-3xl border border-border rounded-2xl p-8 shadow-2xl rotate-2 hover:rotate-0 hover:scale-[1.02] transition-all duration-500 group hover:border-primary-neon/30">
                <div class="flex items-center justify-between mb-8 border-b border-border pb-4">
                    <div class="flex gap-2">
                        <div class="w-3.5 h-3.5 rounded-full bg-red-500/80"></div>
                        <div class="w-3.5 h-3.5 rounded-full bg-yellow-500/80"></div>
                        <div class="w-3.5 h-3.5 rounded-full bg-green-500/80"></div>
                    </div>
                    <div class="text-xs text-muted-foreground font-mono tracking-widest uppercase">focus.ts</div>
                </div>
                
                <div class="space-y-4 font-mono text-sm sm:text-base leading-relaxed text-foreground/70">
                    <div class="flex">
                        <span class="text-secondary-neon mr-2">const</span>
                        <span class="text-primary-neon">fokusUtama</span>
                        <span class="mx-2 text-muted-foreground/30">=</span>
                        <span class="text-foreground/60">{`{`}</span>
                    </div>
                    <div class="pl-6 flex flex-col gap-2">
                        <div>
                            <span class="text-muted-foreground mr-2">role:</span>
                            <span class="text-green-600/80 dark:text-green-400/80" data-i18n-key="hero.code.role">"Solving architecture bottlenecks"</span><span class="text-muted-foreground/30">,</span>
                        </div>
                        <div>
                            <span class="text-muted-foreground mr-2">skillUtama:</span>
                            <span class="text-foreground/60">[</span><span class="text-orange-600/80 dark:text-orange-400/80" data-i18n-key="hero.code.skill1">"Backend"</span><span class="text-muted-foreground/30">, </span><span class="text-orange-600/80 dark:text-orange-400/80" data-i18n-key="hero.code.skill2">"Cloud Deployments"</span><span class="text-foreground/60">]</span><span class="text-muted-foreground/30">,</span>
                        </div>
                        <div>
                            <span class="text-muted-foreground mr-2">impact:</span>
                            <span class="text-green-600/80 dark:text-green-400/80" data-i18n-key="hero.code.impact">"Faster business operations"</span><span class="text-muted-foreground/30">,</span>
                        </div>
                        <div>
                            <span class="text-muted-foreground mr-2">delivery:</span>
                            <span class="text-secondary-neon/80" data-i18n-key="hero.code.delivery">"On Time & Robust"</span>
                        </div>
                    </div>
                    <div class="flex mt-2">
                        <span class="text-foreground/60">{`}`}</span><span class="text-muted-foreground/30">;</span>
                    </div>
                    
                    <div class="flex mt-6 items-center gap-3 pt-6 border-t border-border opacity-50 group-hover:opacity-100 transition-opacity">
                        <span class="w-2 h-2 rounded-full bg-primary-neon animate-ping"></span>
                        <span class="text-xs text-primary-neon uppercase tracking-widest font-semibold flex-1">System is running securely</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import gsap from 'gsap';
    
    const initHeroAnim = () => {
        const tl = gsap.timeline({ defaults: { ease: "power4.out" } });
        
        // Removed Splitting library to avoid layout shifting & generic look, using simple staggered fade-in.
        tl.from("h1 span", {
            y: 40,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            delay: 0.1
        })
        .from("h1 + p", {
            y: 20,
            opacity: 0,
            duration: 0.8
        }, "-=0.6")
        .from(".flex-wrap > div", {
            y: 20,
            opacity: 0,
            duration: 0.6,
            stagger: 0.1
        }, "-=0.6")
        .from(".flex > a", {
            y: 20,
            opacity: 0,
            duration: 0.6,
            stagger: 0.1
        }, "-=0.4")
        .from(".hero-visual", {
            opacity: 0,
            x: 20,
            scale: 0.95,
            duration: 1.2,
            ease: "back.out(1.4)"
        }, "-=0.8");
    };

    // Run on mount
    document.addEventListener('DOMContentLoaded', initHeroAnim);
    document.addEventListener('astro:after-swap', initHeroAnim);
</script>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
