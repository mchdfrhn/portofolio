---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '@/components/Navbar';
import Hero from '@/components/Hero.astro';
import AboutBento from '@/components/AboutBento.astro';
import { Projects } from '@/components/Projects';
import Experience from '@/components/Experience.astro';
import StackMarquee from '@/components/StackMarquee.astro';
import Contact from '@/components/Contact.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="Mochamad Farhan Ali | Fullstack Developer | Vibe Coder">
	<Navbar client:visible />
	
	<main class="w-full max-w-none md:max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16 overflow-x-hidden pt-20 md:pt-32">
        <Hero />
        
        <div class="space-y-16 md:space-y-32">
            <AboutBento />
            <Projects client:visible />
            <Experience />
        </div>
	</main>
    
    <div class="mt-12 md:mt-24">
        <StackMarquee />
    </div>

    <div class="w-full max-w-none md:max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16">
        <Contact />
    </div>

	<Footer />
</Layout>
