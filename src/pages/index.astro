---
import Layout from '../layouts/Layout.astro';
import { Navbar } from '@/components/Navbar';
import Hero from '@/components/Hero.astro';
import AboutBento from '@/components/AboutBento.astro';
import AboutDescription from '@/components/AboutDescription.astro';
import { Projects } from '@/components/Projects';
import Experience from '@/components/Experience.astro';
import StackMarquee from '@/components/StackMarquee.astro';
import Contact from '@/components/Contact.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="Mochamad Farhan Ali | Fullstack Developer | Vibe Coder">
	<Navbar client:visible />
	
	<main class="w-full mx-auto overflow-x-hidden">
        <!-- Hero Section -->
        <div class="px-4 sm:px-10 lg:px-16 pt-20 md:pt-32">
            <Hero />
        </div>
        
        <!-- About Section (Slightly darker/lighter background for depth) -->
        <div class="w-full bg-slate-900/40 border-y border-white/5 shadow-inner mt-16 md:mt-32">
            <div class="max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16 py-24 md:py-32 space-y-24 md:space-y-40">
                <AboutBento />
                <AboutDescription />
            </div>
        </div>

        <!-- Projects & Experience -->
        <div class="max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16 py-24 md:py-32 space-y-24 md:space-y-40">
            <Projects client:visible />
            <Experience />
        </div>
	</main>
    
    <div class="w-full">
        <StackMarquee />
    </div>

    <!-- Contact & Footer -->
    <div class="bg-slate-900/60 shadow-[inset_0_20px_50px_rgba(0,0,0,0.5)]">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-10 lg:px-16 pb-12 pt-24">
            <Contact />
        </div>
    	<Footer />
    </div>
</Layout>
